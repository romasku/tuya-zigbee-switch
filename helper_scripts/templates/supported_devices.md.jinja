{% for device_key, device in devices %}
  {% set manufacturer = "`" ~ (device.stock_manufacturer_name or "unknown") ~ "`" %}
  {% set ns = namespace(model="") %}
  {% if device.stock_model_name is none %}
    {% set ns.model = "`unknown`" %}
  {% elif device.stock_model_name is string %}
    {% set ns.model = "`" ~ device.stock_model_name ~ "`" %}
  {% else %}
    {% for m in device.stock_model_name %}
      {% if loop.first %}
        {% set ns.model = "`" ~ m ~ "`" %}
      {% else %}
        {% set ns.model = ns.model ~ " " ~ "`" ~ m ~ "`" %}
      {% endif %}
    {% endfor %}
  {% endif %}
  {% set model = ns.model %}
  {% set z2m_name = device.override_z2m_device or device.stock_converter_model %}
  {% set z2m_link = "(https://www.zigbee2mqtt.io/devices/" ~ (z2m_name | replace(" ", "_")) ~ ".html)" %}
  {% set human_name = "[" ~ device.human_name ~ "]" ~ z2m_link %}
  {% set info = device.info %}
  {% if device.threads %}
    {% if device.threads is string %}
      {% set threads_links = [device.threads] %}
    {% else %}
      {% set threads_links = device.threads %}
    {% endif %}
    {% set threads_list = [] %}
    {% for url in threads_links %}
      {% set num = url.split("/")[-1] | int %}
      {% set num_str = "`#%03d`" | format(num) %}
      {% set _ = threads_list.append("[" ~ num_str ~ "](" ~ url ~ ")") %}
    {% endfor %}
    {% set threads = threads_list | join(" ") %}
  {% else %}
    {% set threads = " " %}
  {% endif %}
  {% if device.store %}
    {% if device.store is string %}
      {% set store_links = [device.store] %}
    {% else %}
      {% set store_links = device.store %}
    {% endif %}
    {% set store_list = [] %}
    {% for url in store_links %}
      {% if "aliexpress" in url %}
        {% set label = "`AlEx`" %}
      {% elif "amazon" in url %}
        {% set label = "`amzn`" %}
      {% elif "moes" in url %}
        {% set label = "`Moes`" %}
      {% elif "bseed" in url %}
        {% set label = "`BSEED`" %}
      {% else %}
        {% set label = "`Store`" %}
      {% endif %}
      {% set _ = store_list.append("[" ~ label ~ "](" ~ url ~ ")") %}
    {% endfor %}
    {% set store = store_list | join(" ") %}
  {% else %}
    {% set store = " " %}
  {% endif %}
  {% if device.status == "fully_supported" %}
    {% set color = "🟩" %}
  {% elif device.status == "mostly_supported" %}
    {% set color = "🟨" %}
  {% elif device.status == "in_progress" %}
    {% set color = "🟧" %}
  {% elif device.status == "unsupported" %}
    {% set color = "🟥" %}
  {% endif %}
  {% if device.category == "module" %}
    {% set category = "🇲" %}
  {% elif device.category == "switch" %}
    {% set category = "🇸" %}
  {% elif device.category == "remote" %}
    {% set category = "🇷" %}
  {% elif device.category == "outlet" %}
    {% set category = "🇴" %}
  {% elif device.category == "plug" %}
    {% set category = "🇵" %}
  {% elif device.category == "board" %}
    {% set category = "🇧" %}
  {% else %}
    {% set category = "❓" %}
  {% endif %}
  {% if device.build %}
    {% set build = "✔️" %}
  {% else %}
    {% set build = "❌️" %}
  {% endif %}
  {% set batteries = ["AA", "AAA", "CR2016", "CR2025", "CR2032", "CR2430", "CR2450", "LR23A", "18650"] %}
